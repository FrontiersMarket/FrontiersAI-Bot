# =============================================================================
# Frontiers Market Bot - Environment Variables
# =============================================================================
# Copy this file to .env for local development
# For GCP deployment, set these on the instance or via Docker env flags
# =============================================================================

# -----------------------------------------------------------------------------
# REQUIRED VARIABLES
# -----------------------------------------------------------------------------

# Password to access the /setup wizard
# For GCP: Set a secure password in the instance env
# For local: Set any password you want
SETUP_PASSWORD=your-secure-password-here

# Directory where openclaw stores configuration and state
# MUST point to /data (volume mount) for persistence
OPENCLAW_STATE_DIR=/data/.openclaw

# Directory where openclaw stores workspace files
# MUST point to /data (volume mount) for persistence
OPENCLAW_WORKSPACE_DIR=/data/workspace

# -----------------------------------------------------------------------------
# RECOMMENDED VARIABLES
# -----------------------------------------------------------------------------

# Authentication token for the openclaw gateway and Control UI
# For GCP: Generate with: openssl rand -hex 32
# For local: Generate with: openssl rand -hex 32
# If not set, the wrapper will generate one (not ideal for production)
OPENCLAW_GATEWAY_TOKEN=

# -----------------------------------------------------------------------------
# OPTIONAL VARIABLES (Usually don't need to change)
# -----------------------------------------------------------------------------

# Port the wrapper server listens on
PORT=8080

# Internal port where the gateway listens (proxied by the wrapper)
# Default: 18789
INTERNAL_GATEWAY_PORT=18789

# Internal host for the gateway
# Default: 127.0.0.1
INTERNAL_GATEWAY_HOST=127.0.0.1

# Data source for the local SQLite DB
# 'bigquery' — pull ranch data from BigQuery (default, Frontiers Market)
# 'custom'   — connect to your own PostgreSQL / MySQL (see section below)
# DB_SOURCE=bigquery

# BigQuery dataset to pull ranch data from (only used when DB_SOURCE=bigquery)
# Default: public
GBQ_DATASET=public

# -----------------------------------------------------------------------------
# CUSTOM DB (only used when DB_SOURCE=custom)
# -----------------------------------------------------------------------------

# Database type: postgres | mysql
# CUSTOM_DB_TYPE=postgres

# --- SSH Tunnel (optional — omit SSH_HOST to connect to the DB directly) ---
# SSH server hostname
# SSH_HOST=db.example.com
# SSH server port (default: 22)
# SSH_PORT=22
# SSH username
# SSH_USER=ubuntu
# Path to PEM private key file inside the container (preferred)
# SSH_PRIVATE_KEY_PATH=/data/resources/id_rsa
# Passphrase for the private key (only needed if the key is passphrase-protected)
# SSH_KEY_PASSPHRASE=
# OR inline PEM key content
# SSH_PRIVATE_KEY=
# OR SSH password (if no private key)
# SSH_PASSWORD=

# --- Remote DB connection ---
# DB host relative to the SSH server (usually localhost when using SSH tunnel)
# Use the actual hostname when connecting directly (no SSH tunnel)
# CUSTOM_DB_HOST=localhost
# DB port (default: 5432 for postgres, 3306 for mysql)
# CUSTOM_DB_PORT=5432
# Database name
# CUSTOM_DB_NAME=myapp
# DB username
# CUSTOM_DB_USER=readonly_user
# DB password
# CUSTOM_DB_PASSWORD=

# --- Schema ---
# Path to a JSON schema file inside the container that defines which tables
# and columns to sync. If not set, all tables are auto-introspected.
# Schema file format:
#   { "tables": [{ "name": "users", "columns": ["id","email"], "filter": "deleted_at IS NULL" }] }
# CUSTOM_DB_SCHEMA_PATH=/data/custom_db_schema.json

# Path to the openclaw configuration file
# Default: ${OPENCLAW_STATE_DIR}/openclaw.json
# Leave empty to use the default
OPENCLAW_CONFIG_PATH=

# Path to the openclaw CLI entry point
# Default: /usr/local/lib/node_modules/openclaw/dist/entry.js
# Leave empty unless using a custom build
OPENCLAW_ENTRY=/usr/local/lib/node_modules/openclaw/dist/entry.js

# Node.js executable to use
# Default: node
# Leave empty unless you need a specific node binary
OPENCLAW_NODE=node

# Enable chat completions endpoint (/v1/chat/completions)
# Default: false
ENABLE_CHAT_COMPLETIONS=true

# -----------------------------------------------------------------------------
# NOTES
# -----------------------------------------------------------------------------
# 1. For GCP deployment, you MUST have a volume mounted at /data
# 2. Without the volume, configuration will be lost on every container restart
# 3. After deployment, visit http://<your-instance-ip>:8080/setup to configure
# 4. The setup wizard will guide you through onboarding
# =============================================================================
