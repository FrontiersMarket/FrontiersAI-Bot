{
  "name": "frontiersai-bot",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.16.1",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "watch": "turbo run docker:logs dev:watch",
    "shell": "docker exec -it frontiersai-bot bash",
    "tui": "docker exec -it frontiersai-bot node /usr/local/lib/node_modules/openclaw/dist/entry.js tui",
    "up": "docker start frontiersai-bot 2>/dev/null || docker run -d --name frontiersai-bot -p 8080:8080 --env-file .env -v $PWD/.tmpdata:/data frontiersai-bot && echo 'Container started'",
    "down": "docker stop frontiersai-bot 2>/dev/null && echo 'Container stopped'",
    "dev:watch": "node scripts/watch-workspace.mjs",
    "docker:logs": "docker logs -f frontiersai-bot",
    "restart-openclaw": "pnpm run down && pnpm run up",
    "docker:build": "docker build -t frontiersai-bot .",
    "start": "node src/server.js",
    "lint": "node -c src/server.js",
    "clean-messages": "node scripts/clean-bot-messages.mjs",
    "setup:local": "node scripts/setup/index.mjs"
  },
  "dependencies": {
    "@google-cloud/bigquery": "^7.9.4",
    "better-sqlite3": "^11.10.0",
    "express": "^5.2.1",
    "http-proxy": "^1.18.1",
    "node-pty": "^1.1.0",
    "ws": "^8.19.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "node-pty"
    ]
  },
  "devDependencies": {
    "@clack/prompts": "^1.1.0",
    "turbo": "^2.8.17"
  }
}